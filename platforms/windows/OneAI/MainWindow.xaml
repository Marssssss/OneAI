<?xml version="1.0" encoding="utf-8"?>
<!-- MainWindow: custom sidebar (scenarios + recent sessions + new-conversation
     menu + settings) + ChatView content. Ctrl+K opens the command palette.
     Mirrors the macOS NavigationSplitView sidebar. -->
<Window
    x:Class="OneAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OneAI.ViewModels"
    xmlns:n="using:OneAI.Native"
    xmlns:views="using:OneAI.Views"
    Title="OneAI">

    <!-- WinUI 3 Window has no Width/Height/MinWidth/MinHeight XAML members
         (WMC0011); initial size is set in the constructor via AppWindow.Resize. -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!-- Ctrl+K → command palette -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="K" Modifiers="Control" Invoked="CtrlK_Invoked" />
        </Grid.KeyboardAccelerators>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" RowDefinitions="Auto,*,Auto">
            <!-- Top: full-width "新对话" primary action (mirrors the macOS sidebar
                 list head — the old "会话" title + small "新建" button is gone, the
                 brand now lives in the chat detail's top bar). -->
            <Button Grid.Row="0" Click="NewChat_Click" Margin="10,10,10,4" Padding="12,8"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    CornerRadius="10" Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="新对话" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <!-- Scenarios + sessions -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Scenarios section -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Padding="12,8,4,2">
                        <TextBlock Text="场景" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <Button Click="NewScenario_Click" Background="Transparent" BorderThickness="0" Padding="4,0"
                                ToolTipService.ToolTip="新场景">
                            <FontIcon Glyph="&#xE710;" FontSize="11" />
                        </Button>
                    </StackPanel>
                    <ListView ItemsSource="{x:Bind Vm.AgentStore.Scenarios, Mode=OneWay}"
                              SelectionMode="None" IsItemClickEnabled="True" ItemClick="Scenario_Click"
                              Padding="0,0,0,4">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:Scenario">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Padding="6,3">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Icon, Mode=OneWay}" FontSize="14"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Name, Mode=OneWay}" FontSize="13"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Click="EditScenario_Click" Tag="{x:Bind Id, Mode=OneWay}"
                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                            ToolTipService.ToolTip="编辑场景">
                                        <FontIcon Glyph="&#xE70F;" FontSize="11" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Recent sessions section -->
                    <StackPanel Orientation="Horizontal" Padding="12,8,4,2">
                        <TextBlock Text="最近会话" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="SessionList"
                              ItemsSource="{x:Bind Vm.Sessions, Mode=OneWay}"
                              SelectionMode="Single" IsItemClickEnabled="True"
                              ItemClick="Session_Click" Padding="0,0,0,4">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="n:SessionInfo">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="6,3">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind DisplayTitle, Mode=OneWay}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   Text="{x:Bind Summary, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Click="DeleteSession_Click" Tag="{x:Bind Id, Mode=OneWay}"
                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                            ToolTipService.ToolTip="删除">
                                        <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer: settings (top hairline separates it from the list — the
                 button is transparent so its own top border reads as the divider). -->
            <Button Grid.Row="2" Click="Settings_Click" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left" Background="Transparent"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE713;" />
                    <TextBlock Text="设置" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Chat -->
        <views:ChatView x:Name="Chat" Grid.Column="1" />
    </Grid>
</Window>

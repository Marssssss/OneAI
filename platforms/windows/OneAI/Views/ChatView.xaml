<?xml version="1.0" encoding="utf-8"?>
<!-- ChatView: top bar (scenario/title/debrief/tokens/settings) + turn-status
     bar (group only) + first-run hint + message list (user/assistant with
     speaker header) + optional artifact canvas split + error + input bar
     (mic placeholder / send / stop). Mirrors the macOS ChatDetail. -->
<UserControl
    x:Class="OneAI.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:OneAI.ViewModels"
    xmlns:views="using:OneAI.Views">

    <UserControl.Resources>
        <!-- User bubble -->
        <DataTemplate x:Key="UserBubble" x:DataType="vm:UserItem">
            <StackPanel HorizontalAlignment="Right" MaxWidth="360">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="14" Padding="12,8">
                    <TextBlock Text="{x:Bind Text}" FontSize="14" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}" />
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Assistant bubble: speaker header + thinking expander + tool steps +
             streaming plain text (capped) OR markdown + cursor + retry -->
        <DataTemplate x:Key="AssistantBubble" x:DataType="vm:AssistantItem">
            <Grid ColumnDefinitions="3,*" Margin="{x:Bind BubbleMargin, Mode=OneWay}">
                <!-- Left accent bar in the speaker's color (group only) -->
                <Border Grid.Column="0" Width="3" CornerRadius="1.5" Visibility="{x:Bind HasSpeaker, Mode=OneWay}">
                    <Border.Background>
                        <SolidColorBrush Color="{x:Bind SpeakerColorBrush, Mode=OneWay}" />
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Stretch" Margin="6,0,0,0">

                    <!-- Speaker header (group only) -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{x:Bind HasSpeaker, Mode=OneWay}">
                        <TextBlock Text="{x:Bind SpeakerAvatar, Mode=OneWay}" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind SpeakerName, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{x:Bind SpeakerBrush, Mode=OneWay}" VerticalAlignment="Center" />
                        <Border CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{x:Bind SpeakerColorFaint, Mode=OneWay}" />
                            </Border.Background>
                            <TextBlock Text="{x:Bind SpeakerRole, Mode=OneWay}" FontSize="10"
                                       Foreground="{x:Bind SpeakerBrush, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <!-- Thinking card (only when there's thinking text) -->
                    <Expander IsExpanded="{x:Bind ThinkingExpanded, Mode=TwoWay}"
                              Visibility="{x:Bind HasThinking, Mode=OneWay}"
                              HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="10,4">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE955;" FontSize="13" />
                                <TextBlock Text="{x:Bind ThinkingHeader, Mode=OneWay}" FontSize="12" />
                            </StackPanel>
                        </Expander.Header>
                        <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{x:Bind Thinking, Mode=OneWay}" FontSize="12"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Expander>

                    <!-- Tool steps -->
                    <ItemsRepeater ItemsSource="{x:Bind Steps, Mode=OneWay}" Margin="0,2,0,2">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolStep">
                                <StackPanel Spacing="1" Margin="0,2">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock FontSize="11" FontFamily="Consolas"
                                                   Foreground="{x:Bind StepIconColor, Mode=OneWay}"
                                                   Text="{x:Bind StepIcon, Mode=OneWay}" />
                                        <TextBlock FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                                                   Foreground="{x:Bind StepIconColor, Mode=OneWay}"
                                                   Text="{x:Bind StepSummary, Mode=OneWay}" />
                                    </StackPanel>
                                    <TextBlock FontSize="11" FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               Visibility="{x:Bind HasResult, Mode=OneWay}"
                                               Text="{x:Bind ResultPreview, Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Streaming partial text (plain, capped + steady caret).
                         Re-parsing the growing markdown on every token floods
                         the UI thread on long replies. -->
                    <TextBlock Text="{x:Bind StreamingWithCursor, Mode=OneWay}" FontSize="14"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True"
                               Visibility="{x:Bind ShowStreamingTextVis, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                    <!-- Markdown answer (rendered once on completion).
                         Bound to MarkdownText — raised ONLY on the Streaming/Done
                         flips, NOT per token — so the growing Text during
                         streaming never pushes a DP update → OnChanged → full
                         Render() rebuild on every token (the streaming lag). -->
                    <views:MarkdownTextBlock Markdown="{x:Bind MarkdownText, Mode=OneWay}"
                                              Visibility="{x:Bind ShowMarkdownVis, Mode=OneWay}">
                        <views:MarkdownTextBlock.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="重新生成" Click="Retry_Click" />
                                <MenuFlyoutItem Text="复制" Click="CopyAnswer_Click" Tag="{x:Bind Text, Mode=OneWay}" />
                                <MenuFlyoutItem Text="分享" Click="ShareAnswer_Click" Tag="{x:Bind Text, Mode=OneWay}" />
                            </MenuFlyout>
                        </views:MarkdownTextBlock.ContextFlyout>
                    </views:MarkdownTextBlock>

                    <!-- Error + retry -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind HasError, Mode=OneWay}">
                        <TextBlock Text="{x:Bind ErrorWithPrefix, Mode=OneWay}" FontSize="12"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" />
                        <Button Click="Retry_Click" Content="重试" Padding="8,2" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <views:ChatTemplateSelector x:Key="ChatSelector"
            UserTemplate="{StaticResource UserBubble}"
            AssistantTemplate="{StaticResource AssistantBubble}" />
    </UserControl.Resources>

    <Grid>
        <!-- Inline topic-intake page (takes over until confirmed/cancelled) -->
        <ScrollViewer Visibility="{x:Bind Vm.PendingScenarioVis, Mode=OneWay}" Padding="28">
            <StackPanel Spacing="16" MaxWidth="560" HorizontalAlignment="Stretch">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind Vm.PendingScenarioIcon, Mode=OneWay}" FontSize="28" />
                        <TextBlock Text="{x:Bind Vm.PendingScenarioName, Mode=OneWay}" FontSize="20" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
                <ItemsRepeater ItemsSource="{x:Bind Vm.PendingScenarioFields, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TopicField">
                            <StackPanel Spacing="3" Margin="0,4,0,4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind Label, Mode=OneWay}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{x:Bind VisibilityHint, Mode=OneWay}" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <TextBox x:Name="FieldBox" PlaceholderText="{x:Bind Placeholder, Mode=OneWay}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                                         Loaded="FieldBox_Loaded" Tag="{x:Bind Id, Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="开场角色会围绕你输入的信息发言;这些值会作为各角色背景,并写入会话名。留空可直接开始。"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Click="CancelScenario_Click" Content="取消" />
                    <Button Click="StartScenario_Click" Content="开始" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Conversation -->
        <Grid Visibility="{x:Bind Vm.NoPendingScenarioVis, Mode=OneWay}" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">
            <!-- Top bar -->
            <Grid Grid.Row="0" Padding="16,8" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Single-agent: the 3D pixel-tile brand lives in the top bar
                         (mirrors macOS — the old "会话" sidebar title is gone, the
                         gear moved to the sidebar bottom). -->
                    <views:BrandLogo Scale="4.5" VerticalAlignment="Center" Visibility="{x:Bind Vm.NoScenarioVis, Mode=OneWay}" />
                    <TextBlock Text="One AI, Every Platform" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center" Visibility="{x:Bind Vm.NoScenarioVis, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind Vm.CurrentScenarioIcon, Mode=OneWay}" FontSize="16" Visibility="{x:Bind Vm.HasScenarioVis, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind Vm.CurrentScenarioName, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" Visibility="{x:Bind Vm.HasScenarioVis, Mode=OneWay}" />
                    <TextBlock Text="· 总结阶段" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="{x:Bind Vm.DebriefPhaseVis, Mode=OneWay}" VerticalAlignment="Center" />
                    <Button Click="Debrief_Click" Content="结束面试" FontSize="11" Padding="8,2" Visibility="{x:Bind Vm.DebriefButtonVis, Mode=OneWay}" />
                </StackPanel>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="{x:Bind Vm.LastTurnTokensLabel, Mode=OneWay}" />
            </Grid>
            <!-- Hairline below the top bar — structural division (issue: 苍茫). -->
            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Turn-status bar (group only). Bottom hairline separates it from
                 the message list (structural division — issue: 苍茫). -->
            <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16,5"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                    Visibility="{x:Bind Vm.HasScenarioVis, Mode=OneWay}">
                <TextBlock Text="{x:Bind Vm.TurnStatusLabel, Mode=OneWay}" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>

            <!-- First-run hint -->
            <Border Grid.Row="2" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="10"
                    Padding="12,8" Margin="12,6" Visibility="{x:Bind Vm.NeedsKeyConfigVis, Mode=OneWay}">
                <TextBlock Text="未配置 API Key,点击设置 → 填入 kind / model / key 后保存" FontSize="12"
                           Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}" />
            </Border>

            <!-- Message list + optional artifact canvas split. A welcome overlay
                 sits on top (same row) for the empty single-agent conversation. -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                <ListView x:Name="Messages" Grid.Column="0" Padding="12"
                          ItemsSource="{x:Bind Vm.Items, Mode=OneWay}"
                          ItemTemplateSelector="{StaticResource ChatSelector}"
                          SelectionMode="None" IsItemClickEnabled="False"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" />

                <!-- Welcome screen — shown when the conversation is empty, idle,
                     and no topic-intake is pending (mirrors macOS WelcomeScreen).
                     Disappears the moment the first message lands or a turn starts. -->
                <ScrollViewer Grid.Column="0" Padding="28" Visibility="{x:Bind Vm.WelcomeVis, Mode=OneWay}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" MaxWidth="560" HorizontalAlignment="Center">
                        <views:BrandLogo Scale="9" HorizontalAlignment="Center" />
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="One AI, Every Platform" FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="跨平台 AI Agent 框架 · 单 Agent 对话与多角色场景都在这里"
                                       FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Click="Settings_Click" Visibility="{x:Bind Vm.NeedsKeyConfigVis, Mode=OneWay}"
                                HorizontalAlignment="Center" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE713;" FontSize="12" />
                                <TextBlock Text="先配置 Provider 再开始" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <ItemsRepeater ItemsSource="{x:Bind Vm.WelcomeSuggestions, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="8" Orientation="Vertical" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:WelcomeSuggestion">
                                    <Button Click="WelcomeSuggestion_Click" Tag="{x:Bind Text, Mode=OneWay}"
                                            Padding="10,9" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left" Background="Transparent"
                                            BorderThickness="1" CornerRadius="10"
                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Icon, Mode=OneWay}" FontSize="14" />
                                            <TextBlock Text="{x:Bind Text, Mode=OneWay}" FontSize="12"
                                                       TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" x:Name="CanvasHost" Width="420" Visibility="Collapsed"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" />
            </Grid>

            <!-- Error line -->
            <TextBlock Grid.Row="4" Margin="12,4" FontSize="12"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Text="{x:Bind Vm.Error, Mode=OneWay}"
                       Visibility="{x:Bind Vm.HasErrorVis, Mode=OneWay}" />

            <!-- Input bar (mic placeholder + textbox + send/stop) -->
            <Grid Grid.Row="5" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="8" ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Click="Mic_Click" Background="Transparent" BorderThickness="0" Padding="8"
                        IsEnabled="False" ToolTipService.ToolTip="语音识别暂未支持">
                    <FontIcon Glyph="&#xE720;" />
                </Button>
                <TextBox Grid.Column="1" x:Name="InputBox" Text="{x:Bind Vm.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="问点什么…" AcceptsReturn="True" MinHeight="40" MaxHeight="120"
                         TextWrapping="Wrap" KeyDown="InputBox_KeyDown" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <Button Click="Send_Click" Background="{ThemeResource AccentFillColorDefaultBrush}"
                            Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                            Visibility="{x:Bind Vm.SendButtonVis, Mode=OneWay}"
                            IsEnabled="{x:Bind Vm.HasInput, Mode=OneWay}">
                        <FontIcon Glyph="&#xE724;" />
                    </Button>
                    <Button Click="Stop_Click" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                            Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                            Visibility="{x:Bind Vm.StopButtonVis, Mode=OneWay}">
                        <FontIcon Glyph="&#xE71A;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

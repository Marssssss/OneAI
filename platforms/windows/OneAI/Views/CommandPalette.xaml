<?xml version="1.0" encoding="utf-8"?>
<!-- CommandPalette — Ctrl+K palette: fuzzy-filtered switch between scenarios /
     recent sessions, new chat, open settings. Port of macOS CommandPalette.swift. -->
<ContentDialog
    x:Class="OneAI.Views.CommandPalette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:OneAI.Views"
    Title="快速切换"
    PrimaryButtonText="关闭"
    DefaultButton="Primary">

    <StackPanel Spacing="8" Width="440" MaxHeight="440">
        <TextBox x:Name="QueryBox" PlaceholderText="切换场景 / 会话 / 模型…"
                 TextChanged="QueryBox_TextChanged" KeyDown="QueryBox_KeyDown" />
        <ListView x:Name="Results" IsItemClickEnabled="True" ItemClick="Result_Click"
                  SelectionMode="None" MaxHeight="360">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="views:CmdEntry">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="2,4">
                        <TextBlock Grid.Column="0" Text="{x:Bind Icon, Mode=OneWay}" FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Title, Mode=OneWay}" FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{x:Bind Subtitle, Mode=OneWay}" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
